{
  "rewrites": [
    {
      "source": "/sagedo-services.html",
      "destination": "/sagedo-services.html"
    },
    {
      "source": "/llms.txt",
      "destination": "/llms.txt"
    },
    {
      "source": "/services.json",
      "destination": "/sagedo-services.html"
    },
    {
      "source": "/api/:path*",
      "destination": "https://sagedo-website.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "redirects": []
}