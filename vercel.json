{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://sagedo-website.onrender.com/api/:path*"
    },
    {
      "source": "/((?!.*\\.(?:html|css|js|png|jpg|jpeg|svg|ico|json|txt|webp|woff|woff2|ttf)).*)",
      "destination": "/index.html"
    }
  ]
}